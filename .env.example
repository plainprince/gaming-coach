# Gaming Coach Application Configuration

# ===========================================
# LLM / Ollama Configuration
# ===========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:cloud
OLLAMA_TIMEOUT=60000

# ===========================================
# Screenshot Configuration
# ===========================================
SCREENSHOT_ENABLED=true
# SCREENSHOT_QUALITY=80
# SCREENSHOT_DIR=./screenshots
# SCREENSHOT_WIDTH=960
# SCREENSHOT_HEIGHT=540
# SCREENSHOT_PRESET=960p
# SCREENSHOT_SCALE=1.0

# ===========================================
# Text-to-Speech Configuration
# ===========================================
TTS_ENABLED=false
# TTS_PROVIDER: TTS provider to use
# - auto: Uses platform-specific TTS (say on macOS, espeak on Linux, PowerShell on Windows)
# - none: Disables TTS
TTS_PROVIDER=auto

# TTS_RATE: Speech rate (0.5 = half speed, 1.0 = normal, 2.0 = double speed)
TTS_RATE=1.5

# TTS_PITCH: Voice pitch adjustment
# - macOS say: -10 to 10 (0 = default)
# - Linux espeak: -10 to 10 (mapped to 0-99)
# - Windows: Not supported via basic TTS
TTS_PITCH=-2

# ===========================================
# Display Configuration
# ===========================================
DISPLAY_WINDOW_ENABLED=true
# DISPLAY_WINDOW_POSITION: Position of the overlay window
# Options: top-left, top-right, bottom-left, bottom-right, center
DISPLAY_WINDOW_POSITION=top-right
DISPLAY_WINDOW_TRANSPARENCY=0.8
DISPLAY_WINDOW_DURATION=5
# DISPLAY_WINDOW_NO_FOCUS=true
# DISPLAY_WINDOW_PERSIST_DURING_TTS=false

# ===========================================
# Application Settings
# ===========================================
STARTUP_DELAY=3
RATE=30
